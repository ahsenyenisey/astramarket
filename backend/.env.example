# Backend API port'u (frontend bunu proxy'liyor)
PORT=4000

# JWT imzalama anahtari - canli ortamda mutlaka degistir
JWT_SECRET=astra_market_gizli_anahtar_degistir_beni

# MySQL / MariaDB baglanti bilgileri
# XAMPP varsayilan ayarlarinda DB_USER=root, DB_PASSWORD=(bos)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eticaret_db

# Pixabay API key - seed sirasinda urun gorseli cekmek icin.
# 1. pixabay.com'a uye ol (ucretsiz)
# 2. https://pixabay.com/api/docs/  sayfasinda key gosterilir
# 3. Asagiya yapistir. Bos birakirsan placeholder kullanilir.
PIXABAY_API_KEY=
